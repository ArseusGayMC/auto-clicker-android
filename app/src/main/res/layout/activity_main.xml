<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Başlık -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Otomatik Tıklayıcı"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- İzin Durumu -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="İzin Durumu"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_overlay_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌ Overlay izni gerekli"
            android:textSize="14sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btn_grant_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Overlay İznini Ver (Diğer Uygulamaların Üzerinde Göster)"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/tv_accessibility_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌ Accessibility Servisi gerekli"
            android:textSize="14sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btn_grant_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accessibility Ayarlarını Aç"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Bölücü -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray"
            android:layout_marginBottom="24dp" />

        <!-- Kontroller -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yüzen Buton Kontrolü"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_start"
                android:backgroundTint="@color/green" />

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_stop"
                android:backgroundTint="@color/red" />

        </LinearLayout>

        <!-- Tıklama Aralığı -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/interval_label"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/interval_default"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekbar_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="0"
            android:max="450"
            android:progress="50"
            android:layout_marginBottom="28dp" />

        <!-- Kullanım Kılavuzu -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nasıl Kullanılır?"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permissions_description"
            android:textSize="13sp"
            android:lineSpacingExtra="5dp" />

    </LinearLayout>

</ScrollView>
